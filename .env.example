NODE_ENV=production
PORT=3000

DB_URL=postgresql://user:password@host:5432/database?sslmode=require
# DB_HOST=postgres
# DB_PORT=5432
# DB_USERNAME=nearme_user
# DB_PASSWORD=nearme_pass
# DB_NAME=nearme_social

JWT_SECRET=replace_with_a_long_random_secret
# Remember signed-in users for one week. Do not use a non-expiring token.
JWT_EXPIRES_IN=7d

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=NearMe Social <no-reply@example.com>

# Cloudflare R2 profile image storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nearme-images
# Public custom domain or R2 public development URL, without a trailing slash
R2_PUBLIC_URL=https://images.example.com
